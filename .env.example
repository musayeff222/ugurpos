# Hostinger hPanel → Deployments → Settings
#
# Framework:        Express.js  (Vite / React degil!)
# Build command:    npm run build
# Start command:    npm start
# Entry file:       server.js
# Output directory: BOS BIRAKIN  (dist yazmayin!)
# Node.js:          20.x veya 22.x
#
# dist/ klasoru build sirasinda olusur; statik site olarak deploy edilmez.
# Express (server.js) hem API hem dist/ dosyalarini servis eder.

NODE_ENV=production

# Hostinger PORT otomatik verir; genelde 3000
# PORT=3000

JWT_SECRET=degistirin-guclu-bir-anahtar

# Opsiyonel: SQLite (varsayilan server/data)
# DATA_DIR=/home/u123456789/domains/siteniz.com/nodejs/data
