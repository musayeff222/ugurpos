# Hostinger hPanel → Node.js Web App → Build settings
#
# Framework preset: Express.js  (Vite degil!)
# Build command:    npm run hostinger:build
# Start command:    npm start
# Entry file:       app.js
# Output directory: dist
# Node.js version:  20.x veya 22.x
#
# Bu proje full-stack: Express API + React (dist/ Express tarafindan servis edilir)

NODE_ENV=production
PORT=3000

# Zorunlu: guclu rastgele bir deger
JWT_SECRET=degistirin-guclu-bir-anahtar

# Opsiyonel: SQLite ve yuklenen dosyalar (varsayilan: server/data)
# DATA_DIR=/home/u123456789/domains/siteniz.com/nodejs/data
