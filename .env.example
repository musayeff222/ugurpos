# Hostinger hPanel → Deployments → Settings
#
# Framework:        Express.js
# Build command:    npm run build
# Start command:    npm start
# Entry file:       server.js
# Output directory: BOS BIRAKIN
# Node.js:          20.x veya 22.x

NODE_ENV=production
JWT_SECRET=degistirin-guclu-bir-anahtar

# --- MySQL (Hostinger: hPanel → Databases → MySQL) ---
DB_DRIVER=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=u884620139_kullaniciadi
MYSQL_PASSWORD=hpanelden_kopyalayin
MYSQL_DATABASE=u884620139_veritabani
#
# ONEMLI: localhost YAZMAYIN — IPv6 (::1) hatasi verir, 127.0.0.1 kullanin.
# hPanel'de kullaniciyi veritabanina "All privileges" ile baglayin.

# MySQL yoksa SQLite kullanilir (gelistirme / varsayilan)
# DATA_DIR=server/data

# Urun resimleri nodejs/ DISINDA kalir (deploy ile silinmez)
# Hostinger otomatik: domains/cigkofte.az/public_html/uploads/
# Elle ayar icin:
# UPLOADS_DIR=/home/KULLANICI/domains/cigkofte.az/public_html/uploads
#
# /api/health → uploadsDir ve uploadsPersistent kontrol edin
