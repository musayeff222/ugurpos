{
  "name": "benimpos-clone",
  "private": true,
  "type": "module",
  "main": "server.js",
  "description": "Full-stack POS: Express API + React SPA (dist served by server.js)",
  "engines": {
    "node": ">=20 <=22"
  },
  "hostinger": {
    "framework": "express",
    "entryFile": "server.js",
    "buildCommand": "npm run build",
    "startCommand": "npm start",
    "outputDirectory": ""
  },
  "scripts": {
    "capture": "node scripts/capture-panel.js",
    "server": "node server.js",
    "client": "vite",
    "dev": "concurrently -n api,web -c blue,green \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "postbuild": "node scripts/verify-dist.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "start": "node server.js",
    "hostinger:build": "npm run build",
    "seed:cigkofte": "node scripts/seed-cigkofte-products.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "deasync": "^0.1.30",
    "express": "^5.1.0",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.14.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright": "^1.52.0"
  }
}
